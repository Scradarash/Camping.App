<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Camping.App.Views.Calendar.CalendarPopup"
    BackgroundColor="#80000000"
    IsVisible="False"
    InputTransparent="True">

    <Frame
        VerticalOptions="Center"
        HorizontalOptions="Center"
        CornerRadius="12"
        BackgroundColor="White"
        HasShadow="True"
        Padding="15"
        WidthRequest="360"
        HeightRequest="450">

        <Grid RowDefinitions="Auto,Auto,*">

            <Grid ColumnDefinitions="40,*,40" Row="0" Padding="0,0,0,10">
                <Button Text="&#60;" BackgroundColor="Transparent" Clicked="PreviousMonthClicked" />
                <Label x:Name="LblMonth" FontSize="22" HorizontalTextAlignment="Center"/>
                <Button Text="&#62;" BackgroundColor="Transparent" Clicked="NextMonthClicked" />
            </Grid>

            <Grid Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Padding="0,0,0,8">
                <Label Text="M" HorizontalTextAlignment="Center"/>
                <Label Text="D" HorizontalTextAlignment="Center"/>
                <Label Text="W" HorizontalTextAlignment="Center"/>
                <Label Text="D" HorizontalTextAlignment="Center"/>
                <Label Text="V" HorizontalTextAlignment="Center"/>
                <Label Text="Z" HorizontalTextAlignment="Center"/>
                <Label Text="Z" HorizontalTextAlignment="Center"/>
            </Grid>

            <Grid 
                x:Name="CalendarGrid"
                Row="2"
                ColumnDefinitions="*,*,*,*,*,*,*"
                RowDefinitions="*,*,*,*,*,*"/>

        </Grid>

    </Frame>

</ContentView>
